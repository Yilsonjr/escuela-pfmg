# ---------------------------------------------------------------------------
# Supabase — DATABASE_URL (elige UNA según lo que copias del panel)
# ---------------------------------------------------------------------------
#
# Error P1000 "credentials not valid" suele ser:
#   - Contraseña incorrecta o distinta a la de "Database password"
#   - Usuario mal si usas Pooler en puerto 6543 (debe ser postgres.TUREF, no solo postgres)
#   - Caracteres especiales en la contraseña sin codificar (# @ : / ? etc.)
#
# Siempre que puedas, usa el botón del panel para copiar la URI ya armada.

# --- A) Conexión DIRECTA (recomendada para `prisma migrate deploy` / desarrollo)
# Project Settings → Database → Connection string → Method: Direct
# Usuario: postgres   | Host: db.<PROJECT_REF>.supabase.co   | Puerto: 5432
#
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"

# --- B) Pooler — modo transacción (puerto 6543)
# El usuario NO es "postgres": es "postgres.<PROJECT_REF>" (con el ref de tu proyecto).
# Copia la URI desde el panel en "Transaction pooler" para no equivocarte.
#
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require"

# Si tu contraseña tiene símbolos raros, codifica solo la contraseña (ej. en consola del navegador):
#   encodeURIComponent('TuContraseña')

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-un-string-largo-aleatorio"

# Seed (primer usuario / roles de prueba)
SEED_ADMIN_EMAIL="admin@escuela.local"
SEED_ADMIN_PASSWORD="admin1234"
